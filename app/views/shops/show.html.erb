<h1><%= @shop.name %></h1>

<% if @shop.image.attached? %>
  <%= image_tag @shop.image.variant(resize_to_limit: [600, 400]), class: "img-fluid mb-3", alt: @shop.name %>
<% else %>
  <p>No image available.</p>
<% end %>

<%= link_to "Edit", edit_shop_path(@shop), class: "btn btn-secondary me-2" %>
<%= link_to "Back to Shops", shops_path, class: "btn btn-primary" %>
